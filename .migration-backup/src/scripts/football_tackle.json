  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:foot_speed",
      "op": "rises_above",
      "threshold": 0.6,
      "unit": "m/s"
    },
    "end": {
      "signal": "rest",
      "duration_s": 0.5
    },
    "min_duration_s": 0.3,
    "max_duration_s": 2
  },
  "outputs": [
    "knee_angle",
    "hip_angle",
    "trunk_inclination",
    "foot_speed",
    "arm_swing_angle",
    "shoulder_rotation",
    "hip_rotation",
    "shoulder_level",
    "hip_sway",
    "foot_acceleration",
    "foot_strike_angle"
  ],
  "report_highlights": [
    "knee_angle",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
