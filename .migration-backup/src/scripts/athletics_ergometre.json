{
  "id": "athletics_ergometre",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "athletics",
  "gesture": "Ergomètre / tapis roulant — cycle de course",
  "description": "Analyse biomécanique du mouvement de course sur ergomètre ou tapis roulant : inclinaison du tronc, flexion-extension hanche et genou, angle de coude, symétrie de foulée. Usage : test d'effort, rééducation à la course, entraînement.",
  "movement_type": "continuous",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "both",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_foot_index",
    "right_heel"
  ],
  "height": "full",
  "distance_rule": "corps entier + 20%",
  "measures": [
    {
      "id": "knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "cadence",
      "primitive": "cadence",
      "mode": "cyclic",
      "source_measure": "knee_flexion",
      "expose": true
    },
    {
      "id": "knee_flexion_left",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "knee_ang_speed",
      "primitive": "speed",
      "mode": "angular",
      "source_measure": "knee_flexion",
      "expose": true
    },
    {
      "id": "knee_ang_acceleration",
      "primitive": "acceleration",
      "mode": "angular",
      "source_measure": "knee_ang_speed",
      "expose": true
    },
    {
      "id": "foot_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_foot_index",
      "expose": true
    },
    {
      "id": "foot_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "foot_speed",
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_sway",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    }
  ],
