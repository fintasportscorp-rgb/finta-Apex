{
  "id": "boxing_cross",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "boxing",
  "gesture": "Direct arrière (cross)",
  "description": "Direct arrière avec engagement de hanche en vue sagittale. Usage : puissance, enchaînements.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip",
    "left_wrist"
  ],
  "height": "full",
  "measures": [
    {
      "id": "elbow_extension",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "shoulder_advance",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_shoulder",
      "axis": "x",
      "expose": true
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "hip_drive",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": false
    },
    {
      "id": "shoulder_line_tilt",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_shift_x",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    },
    {
      "id": "guard_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "left_wrist",
      "axis": "y",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : extension du bras, pivot tronc et transfert de poids �\u001d Stanley 2018.",
      "rationale_en": "Reference view: arm extension, trunk pivot and weight transfer �\u001d Stanley 2018.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip"
      ],
      "measures": [
        {
          "id": "elbow_extension",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "shoulder_advance",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_shoulder",
          "axis": "x",
          "expose": true
        },
        {
          "id": "trunk_lean",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        },
        {
          "id": "hip_drive",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": false
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : symétrie épaules et projection de la rotation des hanches au pivot.",
      "rationale_en": "Face-on: shoulder symmetry and projection of hip rotation at the pivot.",
      "feasibility_2d": "limited",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip",
        "left_wrist"
      ],
      "measures": [
        {
          "id": "shoulder_line_tilt",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_shift_x",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "x",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        },
        {
          "id": "guard_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "left_wrist",
          "axis": "y",
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "limited",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip",
        "left_wrist"
      ],
      "measures": [
        {
          "id": "shoulder_line_tilt",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_shift_x",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "x",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        },
        {
          "id": "guard_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "left_wrist",
          "axis": "y",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 1.8,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "falls_below",
      "threshold": 0.4,
      "unit": "TL/s"
    },
    "min_duration_s": 0.15,
    "max_duration_s": 3
  },
  "phases": [
    {
      "id": "rotation",
      "until": {
        "signal": "angle:hip_drive",
        "event": "minimum"
      }
    },
    {
      "id": "extension",
      "until": {
        "signal": "speed:wrist_speed",
        "event": "peak"
      }
    },
    {
      "id": "retrait",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:wrist_speed",
    "event": "peak"
  },
  "outputs": [
    "elbow_extension",
    "shoulder_advance",
    "trunk_lean",
    "wrist_speed",
    "shoulder_line_tilt",
    "hip_shift_x",
    "shoulder_rotation",
    "hip_rotation",
    "guard_height"
  ],
  "report_highlights": [
    "elbow_extension",
    "wrist_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "session_type",
      "label": "Type de séance",
      "type": "single_select",
      "options": [
        "bilan initial",
        "suivi",
        "entraînement",
        "compétition"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "laterality",
      "label": "Côté dominant",
      "type": "single_select",
      "options": [
        "droitier",
        "gaucher"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
