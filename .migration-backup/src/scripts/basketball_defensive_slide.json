{
  "id": "basketball_defensive_slide",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "basketball",
  "gesture": "Pas chassé défensif",
  "movement_type": "continuous",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee",
    "left_ankle",
    "right_ankle",
    "left_shoulder",
    "right_shoulder"
  ],
  "height": "full",
  "measures": [
