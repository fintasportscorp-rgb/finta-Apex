      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "y",
      "expose": true
    }
  ],
  "available_views": [
