{
  "id": "athletics_walk",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "athletics",
  "gesture": "Marche athlétique — pose talon",
  "movement_type": "continuous",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "both",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_foot_index",
    "right_shoulder",
    "right_heel"
  ],
  "height": "full",
  "distance_rule": "corps entier + 20%",
  "measures": [
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "cadence",
      "primitive": "cadence",
      "mode": "cyclic",
      "source_measure": "knee_angle",
      "expose": true
    },
    {
      "id": "knee_angle_left",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "ankle_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_knee",
        "right_ankle",
        "right_foot_index"
      ],
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "foot_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_foot_index",
      "expose": true
    },
    {
      "id": "foot_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "foot_speed",
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_sway",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : genou tendu à l'attaque talon, cadence, amplitude du pas — Hanley 2017.",
      "rationale_en": "Reference view: knee straight at heel strike, cadence, stride length — Hanley 2017.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_foot_index",
        "right_shoulder",
        "right_heel"
      ],
      "measures": [
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "cadence",
          "primitive": "cadence",
          "mode": "cyclic",
          "source_measure": "knee_angle",
          "expose": true
        },
        {
          "id": "knee_angle_left",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_hip",
            "left_knee",
            "left_ankle"
          ],
          "expose": true
        },
        {
          "id": "ankle_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_knee",
            "right_ankle",
            "right_foot_index"
          ],
          "expose": true
        },
        {
          "id": "foot_strike_angle",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_heel",
            "right_foot_index"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "foot_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_foot_index",
          "expose": true
        },
        {
          "id": "foot_acceleration",
          "primitive": "acceleration",
          "mode": "linear",
          "source_measure": "foot_speed",
          "expose": true
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : symétrie inter-côtés et déport latéral du bassin (assessment kinésithérapique).",
      "rationale_en": "Face-on: cross-side symmetry and lateral hip sway (physiotherapy assessment).",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_sway",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "x",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_sway",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "x",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "cyclic",
    "cycle_signal": "knee_angle",
    "boundary": "local_maxima",
    "min_duration_s": 0.4,
    "max_duration_s": 2
  },
  "outputs": [
    "knee_angle",
    "knee_angle_left",
    "ankle_angle",
    "trunk_inclination",
    "foot_speed",
    "shoulder_level",
    "hip_sway",
    "shoulder_rotation",
    "hip_rotation",
    "foot_acceleration",
    "foot_strike_angle",
    "cadence"
  ],
  "report_highlights": [
    "knee_angle",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "walking_speed",
      "label": "Allure cible",
      "type": "single_select",
      "options": [
        "lente",
        "modérée",
        "compétition"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "surface_type",
      "label": "Surface",
      "type": "single_select",
      "options": [
        "route",
        "piste",
        "tapis roulant"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "symmetry_pairs": [
    {
      "right": "knee_angle",
      "left": "knee_angle_left"
    }
  ]
}
