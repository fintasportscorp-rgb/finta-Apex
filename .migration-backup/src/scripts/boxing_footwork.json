    {
      "id": "feet_separation",
      "primitive": "position",
      "mode": "distance",
      "point": "right_ankle",
      "reference": "left_ankle",
      "expose": true
    },
    {
      "id": "hip_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "y",
      "expose": true
    },
    {
      "id": "left_knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "right_knee_flexion",
