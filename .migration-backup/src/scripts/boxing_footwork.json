{
  "id": "boxing_footwork",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "boxing",
  "gesture": "Jeu de jambes (footwork)",
  "description": "Déplacement continu en vue frontale : flexion des genoux, niveau hanches, mobilité latérale. Usage : fluidité défensive.",
  "movement_type": "continuous",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee",
    "left_ankle",
    "right_ankle"
  ],
  "height": "full",
