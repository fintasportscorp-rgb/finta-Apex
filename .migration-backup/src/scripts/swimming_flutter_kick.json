{
  "id": "swimming_flutter_kick",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "swimming",
  "gesture": "Battement de jambes (flutter kick)",
  "movement_type": "continuous",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_foot_index",
    "right_heel"
  ],
  "height": "full",
  "distance_rule": "corps entier + 15%",
  "measures": [
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "cadence",
      "primitive": "cadence",
      "mode": "cyclic",
      "source_measure": "knee_angle",
      "expose": true
    },
    {
      "id": "ankle_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_knee",
        "right_ankle",
        "right_foot_index"
      ],
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "ankle_position_y",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_ankle",
      "axis": "y",
      "expose": true
    },
    {
      "id": "ankle_ang_speed",
      "primitive": "speed",
      "mode": "angular",
      "source_measure": "ankle_angle",
      "expose": true
    },
    {
      "id": "ankle_ang_acceleration",
      "primitive": "acceleration",
      "mode": "angular",
      "source_measure": "ankle_ang_speed",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
