  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:knee_flexion",
      "op": "falls_below",
      "threshold": 160,
      "unit": "deg"
    },
    "end": {
      "signal": "rest",
      "duration_s": 0.5
    },
    "min_duration_s": 0.2,
    "max_duration_s": 1.5
  },
  "outputs": [
    "knee_flexion",
    "hip_angle",
    "trunk_inclination",
    "wrist_speed",
    "shoulder_level",
    "arm_abduction_right",
    "shoulder_rotation",
    "hip_rotation",
    "jump_height",
    "neck_angle"
  ],
  "report_highlights": [
    "trunk_inclination",
    "hip_angle"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
