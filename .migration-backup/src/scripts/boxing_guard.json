  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "rest"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.5,
      "unit": "TL/s"
    },
    "min_duration_s": 1.5,
    "max_duration_s": 60
  },
  "outputs": [
    "left_wrist_height",
    "right_wrist_height",
    "fists_separation",
    "left_elbow_angle",
    "right_elbow_angle",
    "trunk_lean",
    "elbow_to_torso",
    "shoulder_rotation",
    "hip_rotation"
  ],
  "report_highlights": [
    "right_wrist_height",
    "trunk_lean"
  ],
  "inputs": [
