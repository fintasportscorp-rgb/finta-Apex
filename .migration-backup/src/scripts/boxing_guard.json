{
  "id": "boxing_guard",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "boxing",
  "gesture": "Garde",
  "description": "Position de garde en vue frontale : hauteur des poings, angle des coudes, aplomb du tronc. Usage : bilan défensif.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_elbow",
    "right_elbow",
    "left_wrist",
    "right_wrist",
    "left_hip",
    "right_hip"
  ],
  "height": "full",
  "measures": [
    {
      "id": "left_wrist_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "left_wrist",
      "axis": "y",
      "expose": true
    },
    {
      "id": "right_wrist_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "y",
      "expose": true
    },
    {
      "id": "fists_separation",
      "primitive": "position",
      "mode": "distance",
      "point": "left_wrist",
      "reference": "right_wrist",
      "expose": true
    },
    {
      "id": "left_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_elbow",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "right_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": false
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "elbow_to_torso",
      "primitive": "position",
      "mode": "distance",
      "point": "right_elbow",
      "reference": "right_hip",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    }
  ],
