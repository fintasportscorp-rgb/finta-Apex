  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:foot_speed",
      "op": "rises_above",
      "threshold": 0.6
    },
    "end": {
      "signal": "speed:foot_speed",
      "op": "falls_below",
      "threshold": 0.3
    },
    "min_duration_s": 0.2,
    "max_duration_s": 1.5
  },
  "outputs": [
    "knee_angle",
    "hip_angle",
    "trunk_inclination",
    "foot_speed",
    "shoulder_tilt",
