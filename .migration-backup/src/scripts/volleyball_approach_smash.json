      "rationale_en": "Reference view: step amplitude, arm swing, horizontal-to-vertical transition at takeoff.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_foot_index",
        "right_heel"
      ],
      "measures": [
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
