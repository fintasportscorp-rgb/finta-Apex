  "discipline": "volleyball",
  "gesture": "Approche d'attaque (course d'approche)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_foot_index",
    "right_heel"
  ],
  "height": "full",
  "measures": [
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "foot_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_foot_index",
      "expose": true
    },
    {
      "id": "foot_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "foot_speed",
      "expose": true
    },
    {
      "id": "shoulder_tilt",
      "primitive": "angle",
      "mode": "segment_axis",
