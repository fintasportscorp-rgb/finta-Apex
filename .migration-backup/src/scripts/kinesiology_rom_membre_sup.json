  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "rest"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.2,
      "unit": "TL/s"
    },
    "min_duration_s": 0.5,
    "max_duration_s": 20
  },
