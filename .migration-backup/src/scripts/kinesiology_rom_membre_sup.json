{
  "id": "kinesiology_rom_membre_sup",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "kinesiology",
  "gesture": "Amplitude articulaire — membre supérieur",
  "description": "Mesure de l'amplitude articulaire active du membre supérieur (épaule, coude) en vue sagittale. Usage : bilan ROM épaule, yoga (postures de bras), tai chi, rééducation. L'utilisateur précisera le côté et le mouvement.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_elbow",
    "right_elbow",
    "left_wrist",
    "right_wrist"
  ],
  "height": "full",
  "measures": [
    {
      "id": "shoulder_abduction_right",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_elbow"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "shoulder_abduction_left",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "left_shoulder",
        "left_elbow"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "elbow_angle_right",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "elbow_angle_left",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_elbow",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": false
    },
    {
      "id": "shoulder_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_shoulder",
        "right_elbow"
      ],
      "expose": true
    },
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "right_arm_elevation_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "left_arm_elevation_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "left_shoulder",
        "left_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "shoulder_level_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    }
  ],
