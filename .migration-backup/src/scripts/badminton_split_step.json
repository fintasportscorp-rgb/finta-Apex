  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:knee_angle_right",
      "op": "falls_below",
      "threshold": 150,
      "unit": "deg"
    },
    "end": {
      "signal": "speed:ankle_speed",
      "op": "falls_below",
      "threshold": 0.4,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 8
  },
  "phases": [
    {
      "id": "reception",
      "until": {
        "signal": "angle:knee_angle_right",
        "event": "minimum"
      }
    },
    {
      "id": "rebond",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:knee_angle_right",
    "event": "minimum"
  },
  "outputs": [
    "feet_separation",
    "left_knee_flexion",
