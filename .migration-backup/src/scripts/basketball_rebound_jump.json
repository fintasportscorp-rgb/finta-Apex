{
  "id": "basketball_rebound_jump",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "basketball",
  "gesture": "Saut au rebond",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee",
    "left_ankle",
    "right_ankle",
    "left_shoulder",
    "right_shoulder",
    "left_wrist",
    "right_wrist"
  ],
  "height": "full",
  "measures": [
    {
      "id": "left_knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "right_knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "left_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "left_shoulder",
        "left_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "right_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": false
    },
    {
      "id": "hip_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "y",
      "expose": true
    },
    {
      "id": "wrist_max_y",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "y",
      "expose": true
    },
    {
      "id": "jump_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "y",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "frontal",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : symétrie du saut, extension simultanée, élévation des bras.",
      "rationale_en": "Reference view: jump symmetry, simultaneous extension, arm elevation.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_hip",
        "right_hip",
        "left_knee",
        "right_knee",
        "left_ankle",
        "right_ankle",
        "left_shoulder",
        "right_shoulder",
        "left_wrist",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "left_knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_hip",
            "left_knee",
            "left_ankle"
          ],
          "expose": true
        },
        {
          "id": "right_knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "left_arm_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "left_shoulder",
            "left_wrist"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "right_arm_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_wrist"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": false
        }
      ]
    },
    {
      "view": "sagittal_right",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Profil : hauteur de saut absolue et élévation maximale du bras.",
      "rationale_en": "Side view: absolute jump height and peak arm elevation.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_shoulder",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "hip_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "y",
          "expose": true
        },
        {
          "id": "wrist_max_y",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_wrist",
