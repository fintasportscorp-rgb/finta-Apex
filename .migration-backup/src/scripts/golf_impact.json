  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:shoulder_tilt",
      "op": "rises_above",
      "threshold": 8,
      "unit": "deg"
    },
    "end": {
      "signal": "rest",
      "duration_s": 0.5
    },
    "min_duration_s": 0.3,
    "max_duration_s": 5
  },
  "outputs": [
    "shoulder_tilt",
    "hip_tilt",
    "left_knee_flexion",
    "right_knee_flexion",
    "wrist_position_x",
    "trunk_inclination",
    "shoulder_rotation",
    "hip_rotation",
    "hip_shoulder_separation",
    "head_stability"
  ],
  "report_highlights": [
    "shoulder_tilt",
    "hip_tilt"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
