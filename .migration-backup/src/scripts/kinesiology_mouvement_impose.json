  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.2,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "falls_below",
      "threshold": 0.1,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 30
  },
  "outputs": [
    "knee_angle_right",
    "knee_angle_left",
    "hip_angle_right",
    "hip_angle_left",
