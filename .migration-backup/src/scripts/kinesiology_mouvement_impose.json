{
  "id": "kinesiology_mouvement_impose",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "kinesiology",
  "gesture": "Mouvement imposé (évaluation fonctionnelle)",
  "description": "Évaluation générique d'un mouvement imposé ou prescrit : angles articulaires des membres supérieurs et inférieurs, inclinaison du tronc, ROM global. Usage : rééducation fonctionnelle, bilan articulaire, prescription motrice, protocole de test imposé.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee",
    "left_shoulder",
    "right_shoulder"
  ],
  "height": "full",
  "measures": [
    {
      "id": "knee_angle_right",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "knee_angle_left",
      "primitive": "angle",
