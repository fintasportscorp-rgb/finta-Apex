{
  "id": "rowing_start",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "rowing",
  "gesture": "Départ (départ standing start)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder"
  ],
  "height": "full",
  "measures": [
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "knee_ang_speed",
      "primitive": "speed",
      "mode": "angular",
      "source_measure": "knee_angle",
      "expose": true
    },
    {
      "id": "knee_ang_acceleration",
      "primitive": "acceleration",
      "mode": "angular",
      "source_measure": "knee_ang_speed",
      "expose": true
    },
    {
      "id": "foot_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_foot_index",
      "expose": false
    },
    {
      "id": "foot_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "foot_speed",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : amplitude des coups partiels en départ, puissance par coup.",
      "rationale_en": "Reference view: partial stroke amplitude at start, power per stroke.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder"
      ],
      "measures": [
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "hip_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "knee_ang_speed",
          "primitive": "speed",
          "mode": "angular",
          "source_measure": "knee_angle",
          "expose": true
        },
        {
          "id": "knee_ang_acceleration",
          "primitive": "acceleration",
          "mode": "angular",
          "source_measure": "knee_ang_speed",
          "expose": true
        },
        {
          "id": "foot_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_foot_index",
          "expose": false
        },
        {
          "id": "foot_acceleration",
          "primitive": "acceleration",
          "mode": "linear",
          "source_measure": "foot_speed",
          "expose": true
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : rotations épaule-hanche et symétrie bilatérale du mouvement.",
      "rationale_en": "Face-on: shoulder-hip rotations and bilateral movement symmetry.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:foot_speed",
      "op": "rises_above",
      "threshold": 0.3
    },
    "end": {
      "signal": "rest",
      "duration_s": 0.5
    },
    "min_duration_s": 0.3,
    "max_duration_s": 2
  },
  "outputs": [
    "knee_angle",
    "hip_angle",
    "trunk_inclination",
    "knee_ang_speed",
    "shoulder_rotation",
    "hip_rotation",
    "knee_ang_acceleration",
    "foot_acceleration"
  ],
  "report_highlights": [
    "knee_angle",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
