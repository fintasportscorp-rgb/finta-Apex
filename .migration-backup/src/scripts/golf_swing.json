  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:shoulder_tilt",
      "op": "rises_above",
      "threshold": 5,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:shoulder_tilt",
      "op": "falls_below",
      "threshold": 3,
      "unit": "deg"
    },
    "min_duration_s": 0.5,
    "max_duration_s": 5
  },
  "phases": [
    {
      "id": "backswing",
      "until": {
        "signal": "angle:shoulder_tilt",
        "event": "rises_to_max"
      }
    },
    {
      "id": "downswing",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:shoulder_tilt",
    "event": "rises_to_max"
  },
  "outputs": [
    "shoulder_angle",
    "trunk_inclination",
    "knee_flexion",
    "wrist_speed",
    "shoulder_tilt",
    "hip_tilt",
    "left_knee_flexion",
    "right_knee_flexion",
    "hip_sway",
    "shoulder_rotation",
    "hip_rotation",
    "hip_shoulder_separation",
    "head_stability",
    "elbow_angle"
  ],
  "report_highlights": [
    "shoulder_tilt",
    "hip_tilt"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "club_type",
      "label": "Club utilisé",
      "type": "single_select",
      "options": [
        "driver",
        "fer",
        "wedge",
        "putter"
      ],
      "scope": "instance",
      "required": false
    },
    {
      "id": "handedness",
      "label": "Latéralité",
      "type": "single_select",
      "options": [
        "droitier",
        "gaucher"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "ball_tracking": {
    "enabled": true,
    "sport_preset": "golf"
  }
