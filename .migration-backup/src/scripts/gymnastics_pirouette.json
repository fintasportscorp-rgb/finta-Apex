{
  "id": "gymnastics_pirouette",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "gymnastics",
  "gesture": "Pirouette (rotation verticale)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee"
