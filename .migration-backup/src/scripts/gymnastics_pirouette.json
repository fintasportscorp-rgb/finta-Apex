      "id": "alignment_vertical",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "hip_center",
        "shoulder_center"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "support_knee",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
