{
  "id": "archery_stance",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "archery",
  "gesture": "Posture de tir (stance)",
  "description": "Posture de tir en vue frontale : aplomb tronc, niveau hanches, genoux non verrouillés. Usage : alignement préalable.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee"
  ],
  "height": "full",
  "measures": [
    {
      "id": "hip_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "knee_angle_right",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "knee_angle_left",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "feet_separation",
      "primitive": "position",
      "mode": "distance",
      "point": "right_ankle",
      "reference": "left_ankle",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": false
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "hip_ankle_alignment",
      "primitive": "position",
      "mode": "distance",
      "point": "right_hip",
      "reference": "right_ankle",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "frontal",
