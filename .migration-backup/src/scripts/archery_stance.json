  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "rest"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.4,
      "unit": "TL/s"
    },
    "min_duration_s": 1.5,
    "max_duration_s": 60
  },
  "outputs": [
    "hip_level",
    "shoulder_level",
    "knee_angle_right",
    "knee_angle_left",
    "feet_separation",
    "trunk_lean",
    "hip_ankle_alignment",
    "shoulder_rotation",
    "hip_rotation"
  ],
  "report_highlights": [
    "trunk_lean",
    "hip_level"
  ],
  "inputs": [
