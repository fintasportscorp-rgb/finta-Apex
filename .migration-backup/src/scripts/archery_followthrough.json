{
  "id": "archery_followthrough",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "archery",
  "gesture": "Suivi (follow-through)",
  "description": "Suivi après lâcher en vue sagittale : maintien bras d'arc, recul bras tirant, stabilité. Usage : qualité de finition.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip"
  ],
  "height": "full",
  "measures": [
    {
      "id": "draw_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_elbow"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "draw_elbow",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": false
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_sway",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : recul du bras tirant et maintien du bras d'arc après le lâcher.",
      "rationale_en": "Reference view: draw arm recoil and bow arm hold after release.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip"
      ],
      "measures": [
        {
          "id": "draw_arm_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_elbow"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "draw_elbow",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "trunk_lean",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": false
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Stabilité latérale du tronc et symétrie d'épaules après le tir �\u001d révèle un basculement compensatoire.",
      "rationale_en": "Lateral trunk stability and shoulder symmetry post-shot �\u001d reveals compensatory tilt.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_sway",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "x",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_sway",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "x",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.5,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "falls_below",
      "threshold": 0.15,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 4
  },
  "phases": [
    {
      "id": "lacher",
      "until": {
        "signal": "speed:wrist_speed",
        "event": "peak"
      }
    },
    {
      "id": "suivi",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:wrist_speed",
    "event": "peak"
  },
  "outputs": [
    "draw_arm_elevation",
    "draw_elbow",
    "trunk_lean",
    "shoulder_level",
    "hip_sway",
    "shoulder_rotation"
  ],
  "report_highlights": [
    "draw_arm_elevation",
    "trunk_lean"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "session_type",
      "label": "Type de séance",
      "type": "single_select",
      "options": [
        "bilan initial",
        "suivi",
        "entraînement",
        "compétition"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "laterality",
      "label": "Côté dominant",
      "type": "single_select",
      "options": [
        "droitier",
        "gaucher"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
