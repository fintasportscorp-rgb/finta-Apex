          ],
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Vue arrière (caméra de poursuite) : angle d'inclinaison du vélo et alignement de la colonne.",
      "rationale_en": "Rear view (chase camera): bike lean angle and spine alignment.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_tilt_post",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_tilt_post",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:shoulder_tilt",
      "op": "rises_above",
      "threshold": 5,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:shoulder_tilt",
      "op": "falls_below",
      "threshold": 3,
      "unit": "deg"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 5
  },
  "outputs": [
    "shoulder_tilt",
    "hip_tilt",
    "right_knee_flexion",
    "left_knee_flexion",
    "shoulder_tilt_post",
    "hip_tilt_post",
    "shoulder_rotation",
    "hip_rotation"
  ],
  "report_highlights": [
    "shoulder_tilt",
    "hip_tilt"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
