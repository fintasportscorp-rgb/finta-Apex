{
  "id": "swimming_butterfly_arms",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "swimming",
  "gesture": "Bras papillon",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_elbow",
    "right_elbow",
    "left_wrist",
    "right_wrist"
  ],
  "height": "full",
  "distance_rule": "corps entier + 15%",
  "measures": [
    {
      "id": "left_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "left_shoulder",
        "left_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "right_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "left_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_elbow",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "right_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "body_roll",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "elbow_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_elbow",
      "axis": "y",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "frontal",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : symétrie des deux bras en récupération aérienne.",
      "rationale_en": "Reference view: arm symmetry during aerial recovery.",
      "feasibility_2d": "limited",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_elbow",
        "right_elbow",
        "left_wrist",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "left_arm_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "left_shoulder",
            "left_wrist"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "right_arm_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_wrist"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "left_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_shoulder",
            "left_elbow",
            "left_wrist"
          ],
          "expose": true
        },
        {
          "id": "right_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "body_roll",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "elbow_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_elbow",
          "axis": "y",
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "limited",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_elbow",
        "right_elbow",
        "left_wrist",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "left_arm_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "left_shoulder",
            "left_wrist"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "right_arm_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_wrist"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "left_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_shoulder",
            "left_elbow",
            "left_wrist"
          ],
          "expose": true
        },
        {
          "id": "right_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "body_roll",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "elbow_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_elbow",
          "axis": "y",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:right_wrist",
      "op": "rises_above",
      "threshold": 0.5,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:right_wrist",
      "op": "falls_below",
      "threshold": 0.3,
      "unit": "TL/s"
    },
    "min_duration_s": 0.2,
    "max_duration_s": 1.5
  },
  "phases": [
    {
      "id": "sortie_eau",
      "until": {
        "signal": "speed:right_wrist",
        "event": "peak"
      }
    },
    {
      "id": "entree_eau",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:right_wrist",
    "event": "peak"
  },
  "outputs": [
    "left_arm_elevation",
    "right_arm_elevation",
    "left_elbow_angle",
    "right_elbow_angle",
    "body_roll",
    "elbow_height"
  ],
  "report_highlights": [
    "right_arm_elevation",
    "right_elbow_angle"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "stroke_rate",
      "label": "Cadence (coups/min)",
      "type": "number",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "pool_length",
      "label": "Longueur bassin",
      "type": "single_select",
      "options": [
        "25m",
        "50m"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "symmetry_pairs": [
    {
      "right": "right_arm_elevation",
      "left": "left_arm_elevation"
    },
    {
      "right": "right_elbow_angle",
      "left": "left_elbow_angle"
    }
  ]
}
