{
  "id": "gymnastics_landing",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "gymnastics",
  "gesture": "Réception (landing)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
