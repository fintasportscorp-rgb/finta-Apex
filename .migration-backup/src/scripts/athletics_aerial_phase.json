{
  "id": "athletics_aerial_phase",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "athletics",
  "gesture": "Phase aérienne (foulée — montée de genou)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder"
  ],
  "height": "full",
  "distance_rule": "corps entier + 20%",
  "measures": [
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "shin_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_knee",
        "right_ankle"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "knee_ang_speed",
      "primitive": "speed",
      "mode": "angular",
      "source_measure": "knee_angle",
      "expose": true
    },
    {
      "id": "knee_ang_acceleration",
      "primitive": "acceleration",
      "mode": "angular",
      "source_measure": "knee_ang_speed",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : la foulée est intrinsèquement sagittale (Mero 1992).",
      "rationale_en": "Reference view: stride is intrinsically sagittal (Mero 1992).",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder"
      ],
      "measures": [
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "hip_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": true
        },
        {
          "id": "shin_angle",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_knee",
            "right_ankle"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "knee_ang_speed",
          "primitive": "speed",
          "mode": "angular",
          "source_measure": "knee_angle",
          "expose": true
        },
        {
          "id": "knee_ang_acceleration",
          "primitive": "acceleration",
          "mode": "angular",
          "source_measure": "knee_ang_speed",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:knee_angle",
      "op": "falls_below",
      "threshold": 120,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:knee_angle",
      "op": "rises_above",
      "threshold": 140,
      "unit": "deg"
    },
    "min_duration_s": 0.1,
    "max_duration_s": 0.6
  },
  "phases": [
    {
      "id": "montee",
      "until": {
        "signal": "angle:knee_angle",
        "event": "minimum"
      }
    },
    {
      "id": "descente",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:knee_angle",
    "event": "minimum"
  },
  "outputs": [
    "knee_angle",
    "hip_angle",
    "shin_angle",
    "knee_ang_speed",
    "knee_ang_acceleration"
  ],
  "report_highlights": [
    "knee_angle",
    "knee_ang_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "sprint_phase",
      "label": "Phase de course",
      "type": "single_select",
      "options": [
        "accélération",
        "vitesse maximale",
        "maintien"
      ],
      "scope": "instance",
      "required": false
    },
    {
      "id": "surface_type",
      "label": "Surface",
      "type": "single_select",
      "options": [
        "piste synthétique",
        "gazon",
        "tartan"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
