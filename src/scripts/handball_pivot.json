{
  "id": "handball_pivot",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "handball",
  "gesture": "Tir du pivot (dos au but)",
  "description": "Appui pivot en vue sagittale : inclinaison tronc, drive hanche, screen. Usage : pivot centre, technique appui.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip"
  ],
  "height": "full",
  "measures": [
    {
      "id": "shoulder_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_elbow"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "hip_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_hip",
      "expose": false
    },
    {
      "id": "hip_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "hip_speed",
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": false
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : extension bras à la frappe après pivot ; la rotation elle-même est out-of-plane (descriptive).",
      "rationale_en": "Reference view: arm extension at shot after pivot; rotation itself is out-of-plane (descriptive).",
      "feasibility_2d": "limited",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_elbow"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "trunk_lean",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        },
        {
          "id": "hip_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_hip",
          "expose": false
        },
        {
          "id": "hip_acceleration",
          "primitive": "acceleration",
          "mode": "linear",
          "source_measure": "hip_speed",
          "expose": true
        },
        {
          "id": "hip_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": false
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:hip_speed",
      "op": "rises_above",
      "threshold": 0.4,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:hip_speed",
      "op": "falls_below",
      "threshold": 0.15,
      "unit": "TL/s"
    },
    "min_duration_s": 0.2,
    "max_duration_s": 4
  },
  "phases": [
    {
      "id": "appui",
      "until": {
        "signal": "angle:hip_angle",
        "event": "minimum"
      }
    },
    {
      "id": "tir",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:hip_angle",
    "event": "minimum"
  },
  "outputs": [
    "shoulder_elevation",
    "elbow_angle",
    "trunk_lean",
    "wrist_speed",
    "hip_acceleration"
  ],
  "report_highlights": [
    "trunk_lean",
    "wrist_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "session_type",
      "label": "Type de séance",
      "type": "single_select",
      "options": [
        "bilan initial",
        "suivi",
        "entraînement",
        "compétition"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "laterality",
      "label": "Côté dominant",
      "type": "single_select",
      "options": [
        "droitier",
        "gaucher"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "ball_tracking": {
    "enabled": true,
    "sport_preset": "handball"
  }
}
