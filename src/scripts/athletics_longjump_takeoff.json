{
  "id": "athletics_longjump_takeoff",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "athletics",
  "gesture": "Saut en longueur — appel",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "auto",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_foot_index",
    "left_hip",
    "left_knee",
    "left_ankle",
    "right_heel"
  ],
  "height": "full",
  "distance_rule": "corps entier + 20%",
  "measures": [
    {
      "id": "takeoff_knee",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "swing_knee",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "foot_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_foot_index",
      "expose": true
    },
    {
      "id": "foot_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "foot_speed",
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : takeoff angle, swing leg drive, trunk lean — Lees 1994.",
      "rationale_en": "Reference view: takeoff angle, swing leg drive, trunk lean — Lees 1994.",
      "feasibility_2d": "ok",
      "side": "auto",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_foot_index",
        "left_hip",
        "left_knee",
        "left_ankle",
        "right_heel"
      ],
      "measures": [
        {
          "id": "takeoff_knee",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "swing_knee",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_hip",
            "left_knee",
            "left_ankle"
          ],
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "foot_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_foot_index",
          "expose": true
        },
        {
          "id": "foot_acceleration",
          "primitive": "acceleration",
          "mode": "linear",
          "source_measure": "foot_speed",
          "expose": true
        },
        {
          "id": "foot_strike_angle",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_heel",
            "right_foot_index"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:takeoff_knee",
      "op": "falls_below",
      "threshold": 160,
      "unit": "deg"
    },
    "end": {
      "signal": "speed:right_foot_index",
      "op": "rises_above",
      "threshold": 1,
      "unit": "TL/s"
    },
    "min_duration_s": 0.1,
    "max_duration_s": 0.5
  },
  "phases": [
    {
      "id": "appel",
      "until": {
        "signal": "angle:takeoff_knee",
        "event": "minimum"
      }
    },
    {
      "id": "envol",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:takeoff_knee",
    "event": "minimum"
  },
  "outputs": [
    "takeoff_knee",
    "swing_knee",
    "trunk_inclination",
    "foot_speed",
    "foot_acceleration",
    "foot_strike_angle"
  ],
  "report_highlights": [
    "takeoff_knee",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "surface_type",
      "label": "Surface de piste",
      "type": "single_select",
      "options": [
        "synthétique",
        "tartan",
        "sable"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "dominant_leg",
      "label": "Jambe d'appel",
      "type": "single_select",
      "options": [
        "droite",
        "gauche"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
