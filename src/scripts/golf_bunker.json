{
  "id": "golf_bunker",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "golf",
  "gesture": "Sortie de bunker",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip",
    "right_knee",
    "right_ankle",
    "nose"
  ],
  "height": "full",
  "measures": [
    {
      "id": "wrist_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "shoulder_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_shoulder",
        "right_elbow"
      ],
      "expose": true
    },
    {
      "id": "knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "head_stability",
      "primitive": "position",
      "mode": "amplitude",
      "point": "nose",
      "axis": "x",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : angle d'attaque descendant et wrist hinge maintenu — invariants du bunker shot.",
      "rationale_en": "Reference view: descending attack angle and maintained wrist hinge — bunker shot invariants.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip",
        "right_knee",
        "right_ankle",
        "nose"
      ],
      "measures": [
        {
          "id": "wrist_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "shoulder_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_shoulder",
            "right_elbow"
          ],
          "expose": true
        },
        {
          "id": "knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        },
        {
          "id": "head_stability",
          "primitive": "position",
          "mode": "amplitude",
          "point": "nose",
          "axis": "x",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.3,
      "unit": "m/s"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "falls_below",
      "threshold": 0.2,
      "unit": "m/s"
    },
    "min_duration_s": 0.2,
    "max_duration_s": 2.5
  },
  "outputs": [
    "wrist_angle",
    "shoulder_angle",
    "knee_flexion",
    "trunk_inclination",
    "wrist_speed",
    "head_stability"
  ],
  "report_highlights": [
    "wrist_angle",
    "wrist_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
