{
  "id": "archery_bow_arm",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "archery",
  "gesture": "Alignement bras d'arc",
  "description": "Alignement statique du bras d'arc en vue frontale : hauteur, extension coude, épaule basse. Usage : reproductibilité balistique.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "left_elbow",
    "left_wrist",
    "right_shoulder",
    "right_hip"
  ],
  "height": "full",
  "measures": [
    {
      "id": "bow_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "left_shoulder",
        "left_elbow"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "bow_elbow",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_elbow",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
