{
  "id": "kinesiology_flexion_tronc",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "kinesiology",
  "gesture": "Flexion du tronc (avant)",
  "description": "Mesure de la flexion antérieure du tronc : inclinaison, charnière de hanche, flexion de genou. Usage : bilan de souplesse, yoga (uttanasana, flexion avant), tai chi, test de chaîne postérieure.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_wrist"
  ],
  "height": "full",
  "measures": [
    {
      "id": "hip_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "y",
      "expose": true
    },
    {
      "id": "hip_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_hip",
      "expose": false
    },
    {
      "id": "hip_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "hip_speed",
      "expose": true
    },
    {
      "id": "hip_hinge",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": false
    },
    {
      "id": "shoulder_level_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_level_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "spine_alignment_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "hip_center",
        "shoulder_center"
      ],
      "axis": "vertical",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : amplitude lombo-pelvienne, hip hinge vs flexion lombaire.",
      "rationale_en": "Reference view: lumbo-pelvic range, hip hinge vs lumbar flexion.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "hip_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": true
        },
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_wrist",
          "axis": "y",
          "expose": true
        },
        {
          "id": "hip_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_hip",
          "expose": false
        },
        {
          "id": "hip_acceleration",
          "primitive": "acceleration",
          "mode": "linear",
          "source_measure": "hip_speed",
          "expose": true
        },
        {
          "id": "hip_hinge",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": false
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Vue arrière : test d'Adams (dépistage scoliose) — asymétrie scapulaire et bascule pelvienne en flexion.",
      "rationale_en": "Rear view: Adams forward bend test (scoliosis screening) — scapular asymmetry and pelvic tilt.",
      "feasibility_2d": "ok",
      "side": "both",
      "measures": [
        {
          "id": "shoulder_level_post",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_level_post",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "spine_alignment_post",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "hip_center",
            "shoulder_center"
          ],
          "axis": "vertical",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "rest"
    },
    "end": {
      "signal": "speed:hip_speed",
      "op": "rises_above",
      "threshold": 0.15,
      "unit": "TL/s"
    },
    "min_duration_s": 0.5,
    "max_duration_s": 20
  },
  "phases": [
    {
      "id": "descente",
      "until": {
        "signal": "angle:hip_hinge",
        "event": "minimum"
      }
    },
    {
      "id": "tenue",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:hip_hinge",
    "event": "minimum"
  },
  "outputs": [
    "hip_flexion",
    "knee_angle",
    "trunk_inclination",
    "wrist_height",
    "shoulder_level_post",
    "hip_level_post",
    "spine_alignment_post",
    "hip_acceleration"
  ],
  "report_highlights": [
    "trunk_inclination",
    "hip_flexion"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "session_type",
      "label": "Type de séance",
      "type": "single_select",
      "options": [
        "bilan initial",
        "suivi",
        "rééducation",
        "entraînement"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "position_name",
      "label": "Nom de l'exercice",
      "type": "text",
      "scope": "instance",
      "required": false
    },
    {
      "id": "rpe_physical",
