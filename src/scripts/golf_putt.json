          ],
          "expose": true
        },
        {
          "id": "right_knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        },
        {
          "id": "hip_shoulder_separation",
          "primitive": "rotation",
          "mode": "separation",
          "points": [
            "left_shoulder",
            "right_shoulder",
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.1,
      "unit": "m/s"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "falls_below",
      "threshold": 0.05,
      "unit": "m/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 3
  },
  "outputs": [
    "shoulder_tilt",
    "hip_stability",
    "left_knee_flexion",
    "right_knee_flexion",
    "wrist_speed",
    "wrist_path_x",
    "trunk_inclination",
    "shoulder_rotation",
    "hip_rotation",
    "hip_shoulder_separation",
    "head_stability"
  ],
  "report_highlights": [
    "shoulder_tilt",
    "wrist_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "putt_distance",
      "label": "Distance du putt",
      "type": "single_select",
      "options": [
        "courte",
        "moyenne",
        "longue"
      ],
      "required": false
    },
    {
      "id": "green_slope",
      "label": "Inclinaison du green",
      "type": "single_select",
      "options": [
        "plat",
        "pente"
      ],
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "ball_tracking": {
    "enabled": true,
