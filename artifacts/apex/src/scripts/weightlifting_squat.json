{
  "id": "weightlifting_squat",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "weightlifting",
  "gesture": "Squat (descente-remontée)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "both",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_foot_index",
    "right_heel"
  ],
  "height": "full",
  "distance_rule": "corps entier + 15%",
  "measures": [
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "knee_ang_speed",
      "primitive": "speed",
      "mode": "angular",
      "source_measure": "knee_angle",
      "expose": true
    },
    {
      "id": "knee_ang_acceleration",
      "primitive": "acceleration",
      "mode": "angular",
      "source_measure": "knee_ang_speed",
      "expose": true
    },
    {
      "id": "knee_alignment_right",
      "primitive": "position",
      "mode": "distance",
      "point": "right_knee",
      "reference": "right_ankle",
      "expose": true
    },
    {
      "id": "knee_alignment_left",
      "primitive": "position",
      "mode": "distance",
      "point": "left_knee",
      "reference": "left_ankle",
      "expose": true
    },
    {
      "id": "hip_drop",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "ankle_dorsiflexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_knee",
        "right_ankle",
        "right_foot_index"
      ],
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : flexion genou, hip hinge, inclinaison tronc — Schoenfeld 2010.",
      "rationale_en": "Reference view: knee flexion, hip hinge, trunk inclination — Schoenfeld 2010.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_foot_index",
        "right_heel"
      ],
      "measures": [
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "hip_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "knee_ang_speed",
          "primitive": "speed",
          "mode": "angular",
          "source_measure": "knee_angle",
          "expose": true
        },
        {
          "id": "knee_ang_acceleration",
          "primitive": "acceleration",
          "mode": "angular",
          "source_measure": "knee_ang_speed",
          "expose": true
        },
        {
          "id": "ankle_dorsiflexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_knee",
            "right_ankle",
            "right_foot_index"
          ],
          "expose": true
        },
        {
          "id": "foot_strike_angle",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_heel",
            "right_foot_index"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : knee tracking (alignement vertical genou-cheville), prévention valgus.",
      "rationale_en": "Face-on: knee tracking (vertical knee-ankle alignment), valgus prevention.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_hip",
        "right_hip",
        "left_knee",
        "right_knee",
        "left_ankle",
        "right_ankle"
      ],
      "measures": [
        {
          "id": "knee_alignment_right",
          "primitive": "position",
          "mode": "distance",
          "point": "right_knee",
          "reference": "right_ankle",
          "expose": true
        },
        {
          "id": "knee_alignment_left",
          "primitive": "position",
          "mode": "distance",
          "point": "left_knee",
          "reference": "left_ankle",
          "expose": true
        },
        {
          "id": "hip_drop",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_hip",
        "right_hip",
        "left_knee",
        "right_knee",
        "left_ankle",
        "right_ankle"
      ],
      "measures": [
        {
          "id": "knee_alignment_right",
          "primitive": "position",
          "mode": "distance",
          "point": "right_knee",
          "reference": "right_ankle",
          "expose": true
        },
        {
          "id": "knee_alignment_left",
          "primitive": "position",
          "mode": "distance",
          "point": "left_knee",
          "reference": "left_ankle",
          "expose": true
        },
        {
          "id": "hip_drop",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:knee_angle",
      "op": "falls_below",
      "threshold": 168,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:knee_angle",
      "op": "rises_above",
      "threshold": 168,
      "unit": "deg"
    },
    "min_duration_s": 1,
    "max_duration_s": 10
  },
  "phases": [
    {
      "id": "descente",
      "until": {
        "signal": "angle:knee_angle",
        "event": "minimum"
      }
    },
    {
      "id": "bas",
      "until": {
        "signal": "angle:knee_angle",
        "event": "begins_rising"
      }
    },
    {
      "id": "remontee",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:knee_angle",
    "event": "minimum"
  },
  "outputs": [
    "knee_angle",
    "hip_angle",
    "trunk_inclination",
    "knee_ang_speed",
    "knee_alignment_right",
    "knee_alignment_left",
    "hip_drop",
    "ankle_dorsiflexion",
    "knee_ang_acceleration",
    "foot_strike_angle"
  ],
  "report_highlights": [
    "knee_angle",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "load_kg",
      "label": "Charge (kg)",
      "type": "number",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "squat_type",
      "label": "Type de squat",
      "type": "single_select",
      "options": [
        "squat barre haute",
        "squat barre basse",
        "goblet squat",
        "sans charge"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "symmetry_pairs": [
    {
      "right": "knee_alignment_right",
      "left": "knee_alignment_left"
    }
  ]
}
