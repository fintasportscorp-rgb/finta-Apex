{
  "id": "weightlifting_overhead_press",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "weightlifting",
  "gesture": "Développé militaire (overhead press)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "both",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip"
  ],
  "height": "full",
  "measures": [
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "shoulder_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_position_x",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "x",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "left_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_elbow",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "right_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_separation",
      "primitive": "position",
      "mode": "distance",
      "point": "left_wrist",
      "reference": "right_wrist",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : trajectoire verticale barre, extension coude, stabilité tronc.",
      "rationale_en": "Reference view: vertical bar path, elbow extension, trunk stability.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip"
      ],
      "measures": [
        {
          "id": "elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "shoulder_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_position_x",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_wrist",
          "axis": "x",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : symétrie inter-bras et alignement épaule-coude au lockout.",
      "rationale_en": "Face-on: cross-arm symmetry and shoulder-elbow alignment at lockout.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_elbow",
        "right_elbow",
        "left_wrist",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "left_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_shoulder",
            "left_elbow",
            "left_wrist"
          ],
          "expose": true
        },
        {
          "id": "right_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "wrist_separation",
          "primitive": "position",
          "mode": "distance",
          "point": "left_wrist",
          "reference": "right_wrist",
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_elbow",
        "right_elbow",
        "left_wrist",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "left_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_shoulder",
            "left_elbow",
            "left_wrist"
          ],
          "expose": true
        },
        {
          "id": "right_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "wrist_separation",
          "primitive": "position",
          "mode": "distance",
          "point": "left_wrist",
          "reference": "right_wrist",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:elbow_angle",
      "op": "falls_below",
      "threshold": 90,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:elbow_angle",
      "op": "rises_above",
      "threshold": 160,
      "unit": "deg"
    },
    "min_duration_s": 0.5,
    "max_duration_s": 5
  },
  "outputs": [
    "elbow_angle",
    "shoulder_elevation",
    "wrist_position_x",
    "wrist_speed",
    "left_elbow_angle",
    "right_elbow_angle",
    "wrist_separation"
  ],
  "report_highlights": [
    "elbow_angle",
    "shoulder_elevation"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "load_kg",
      "label": "Charge (kg)",
      "type": "number",
      "required": false
    },
    {
      "id": "grip_width",
      "label": "Largeur de prise",
      "type": "single_select",
      "options": [
        "standard",
        "large"
      ],
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "symmetry_pairs": [
    {
      "right": "right_elbow_angle",
      "left": "left_elbow_angle"
    }
  ]
}
