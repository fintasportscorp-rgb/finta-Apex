{
  "id": "boxing_bob_weave",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "boxing",
  "gesture": "Esquive bob & weave",
  "description": "Esquive avec flexion/translation en vue frontale : inclinaison latérale, flexion genoux. Usage : défense corps, contre-attaque.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee",
    "left_ankle",
    "right_ankle"
  ],
  "height": "full",
  "measures": [
    {
      "id": "head_position_y",
      "primitive": "position",
      "mode": "amplitude",
      "point": "nose",
      "axis": "y",
      "expose": true
    },
    {
      "id": "head_position_x",
      "primitive": "position",
      "mode": "amplitude",
      "point": "nose",
      "axis": "x",
      "expose": true
    },
    {
      "id": "left_knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "right_knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "trunk_lean_lateral",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "hip_center",
        "shoulder_center"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "hip_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_hip",
      "expose": false
    },
    {
      "id": "hip_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "hip_speed",
      "expose": true
    },
    {
      "id": "knee_angle_right",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": false
    },
    {
      "id": "trunk_lateral",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": false
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    }
  ],
