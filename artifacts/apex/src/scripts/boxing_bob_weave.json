  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:hip_speed",
      "op": "rises_above",
      "threshold": 0.4,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:hip_speed",
      "op": "falls_below",
      "threshold": 0.15,
      "unit": "TL/s"
    },
    "min_duration_s": 0.2,
    "max_duration_s": 2.5
  },
  "phases": [
    {
      "id": "descente",
      "until": {
        "signal": "angle:knee_angle_right",
        "event": "minimum"
      }
    },
    {
      "id": "translation",
      "until": {
        "signal": "angle:trunk_lateral",
        "event": "maximum"
      }
    },
    {
      "id": "remontee",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:trunk_lateral",
    "event": "maximum"
  },
  "outputs": [
    "head_position_y",
    "head_position_x",
    "left_knee_flexion",
    "right_knee_flexion",
    "trunk_lean_lateral",
    "shoulder_rotation",
    "hip_rotation",
    "hip_acceleration"
  ],
  "report_highlights": [
    "trunk_lean_lateral",
    "right_knee_flexion"
  ],
  "inputs": [
