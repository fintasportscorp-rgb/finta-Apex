{
  "id": "kinesiology_equilibre_statique",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "kinesiology",
  "gesture": "Équilibre statique (single-leg ou bipodal)",
  "description": "Évaluation de l'équilibre statique en vue frontale : oscillations latérales du tronc, alignement des genoux. Usage : pose de l'arbre (yoga), stance de tai chi, bilan proprioceptif, unipodal ou bilatéral.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee",
    "left_ankle",
    "right_ankle"
  ],
  "height": "full",
  "measures": [
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "cog_position_x",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "knee_alignment_right",
      "primitive": "position",
      "mode": "distance",
      "point": "right_knee",
      "reference": "right_ankle",
      "expose": true
    },
    {
      "id": "ankle_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_ankle",
      "expose": false
    },
    {
      "id": "ankle_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "ankle_speed",
      "expose": true
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "cog_position_x_sag",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "spine_alignment_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "hip_center",
        "shoulder_center"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "shoulder_level_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_level_post",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    }
  ],
