{
  "id": "swimming_crawl_pull",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "swimming",
  "gesture": "Traction crawl (pull)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip"
  ],
  "height": "full",
  "distance_rule": "corps entier + 15%",
  "measures": [
    {
      "id": "shoulder_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_shoulder",
        "right_elbow"
      ],
      "expose": true
    },
    {
      "id": "elbow_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "arm_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "elbow_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_elbow",
      "axis": "y",
      "expose": true
    },
    {
      "id": "body_roll",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence (bord de piscine) : high-elbow catch, traction en S, vitesse poignet.",
      "rationale_en": "Reference view (poolside): high-elbow catch, S-pull, wrist speed.",
      "feasibility_2d": "limited",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_shoulder",
            "right_elbow"
          ],
          "expose": true
        },
        {
          "id": "elbow_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "arm_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_wrist"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        },
        {
          "id": "elbow_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_elbow",
          "axis": "y",
          "expose": true
        },
        {
          "id": "body_roll",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:shoulder_angle",
      "op": "rises_above",
      "threshold": 120,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:shoulder_angle",
      "op": "falls_below",
      "threshold": 60,
      "unit": "deg"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 2
  },
  "phases": [
    {
      "id": "entree",
      "until": {
        "signal": "angle:elbow_flexion",
        "event": "minimum"
      }
    },
    {
      "id": "traction",
      "until": {
        "signal": "speed:right_wrist",
        "event": "peak"
      }
    },
    {
      "id": "sortie",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:right_wrist",
    "event": "peak"
  },
  "outputs": [
    "shoulder_angle",
    "elbow_flexion",
    "arm_inclination",
    "wrist_speed",
    "elbow_height",
    "body_roll"
  ],
  "report_highlights": [
    "elbow_flexion",
    "wrist_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "stroke_rate",
      "label": "Cadence (coups/min)",
      "type": "number",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "pool_length",
      "label": "Longueur bassin",
      "type": "single_select",
      "options": [
        "25m",
        "50m"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
