{
  "id": "boxing_hook",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "boxing",
  "gesture": "Crochet",
  "description": "Crochet en vue frontale : coude à 90°, abduction épaule, engagement tronc. Usage : puissance latérale.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip",
    "left_shoulder",
    "left_hip",
    "left_wrist"
  ],
  "height": "full",
  "measures": [
    {
      "id": "elbow_angle_right",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "arm_abduction",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_elbow"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "trunk_lean_lateral",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "hip_center",
        "shoulder_center"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    },
    {
      "id": "weight_transfer",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "guard_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "left_wrist",
      "axis": "y",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "frontal",
