{
  "id": "swimming_backstroke_rotation",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "swimming",
  "gesture": "Rotation du tronc en dos crawlé",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_hip",
    "right_hip"
  ],
  "height": "full",
  "distance_rule": "corps entier + 15%",
  "measures": [
    {
      "id": "trunk_rotation_projected",
      "primitive": "rotation",
      "mode": "orientation",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "shoulder_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_shoulder",
        "right_elbow"
      ],
      "expose": false
    },
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": false
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    },
    {
      "id": "elbow_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_elbow",
      "axis": "y",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "frontal",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : depuis le bord, caméra perpendiculaire à la lane — rotation projetée du tronc.",
      "rationale_en": "Reference view: from poolside, camera perpendicular to lane — projected trunk rotation.",
      "feasibility_2d": "limited",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "trunk_rotation_projected",
          "primitive": "rotation",
          "mode": "orientation",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "expose": true
        },
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "shoulder_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_shoulder",
            "right_elbow"
          ],
          "expose": false
        },
        {
          "id": "elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": false
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        },
        {
          "id": "elbow_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_elbow",
          "axis": "y",
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "limited",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "trunk_rotation_projected",
          "primitive": "rotation",
          "mode": "orientation",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "expose": true
        },
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "hip_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "shoulder_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_shoulder",
            "right_elbow"
          ],
          "expose": false
        },
        {
          "id": "elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": false
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        },
        {
          "id": "elbow_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_elbow",
          "axis": "y",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:shoulder_angle",
      "op": "rises_above",
      "threshold": 90,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:shoulder_angle",
      "op": "falls_below",
      "threshold": 30,
      "unit": "deg"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 1.5
  },
  "phases": [
    {
      "id": "entree_eau",
      "until": {
        "signal": "angle:elbow_angle",
        "event": "minimum"
      }
    },
    {
      "id": "traction",
      "until": {
        "signal": "speed:right_wrist",
        "event": "peak"
      }
    },
    {
      "id": "sortie",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:right_wrist",
    "event": "peak"
  },
  "outputs": [
    "trunk_rotation_projected",
    "shoulder_level",
    "hip_level",
    "shoulder_rotation",
    "hip_rotation",
    "elbow_height"
  ],
  "report_highlights": [
    "trunk_rotation_projected",
    "shoulder_level"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "stroke_rate",
      "label": "Cadence (coups/min)",
      "type": "number",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "pool_length",
      "label": "Longueur bassin",
      "type": "single_select",
      "options": [
        "25m",
        "50m"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
