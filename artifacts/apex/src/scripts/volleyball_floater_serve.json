{
  "id": "volleyball_floater_serve",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "volleyball",
  "gesture": "Service flottant (floater)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
