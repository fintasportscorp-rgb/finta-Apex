      "point": "right_elbow",
      "expose": true
    },
    {
      "id": "elbow_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "elbow_speed",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : trajet rectiligne main, élévation bras, stabilité tronc.",
      "rationale_en": "Reference view: linear hand path, arm elevation, trunk stability.",
