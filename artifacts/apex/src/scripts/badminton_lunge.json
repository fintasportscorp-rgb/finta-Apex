        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:front_knee_angle",
      "op": "falls_below",
      "threshold": 135,
      "unit": "deg"
    },
    "end": {
      "signal": "speed:ankle_speed",
      "op": "falls_below",
      "threshold": 0.3,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 8
  },
  "phases": [
    {
      "id": "fente",
      "until": {
        "signal": "angle:front_knee_angle",
        "event": "minimum"
      }
    },
    {
      "id": "retour",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:front_knee_angle",
    "event": "minimum"
  },
  "outputs": [
    "front_knee_angle",
    "hip_angle",
    "ankle_angle",
    "trunk_lean",
    "knee_alignment_x",
    "hip_drop",
    "ankle_acceleration",
    "foot_strike_angle"
  ],
  "report_highlights": [
    "front_knee_angle",
    "trunk_lean"
  ],
  "inputs": [
