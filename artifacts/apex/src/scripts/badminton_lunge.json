{
  "id": "badminton_lunge",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "badminton",
  "gesture": "Fente avant (lunge)",
  "description": "Fente vers le filet : flexion genou avant, inclinaison tronc, extension cheville. Usage : déplacement offensif.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_foot_index",
    "right_heel"
  ],
  "height": "full",
  "measures": [
    {
      "id": "front_knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "ankle_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_knee",
        "right_ankle",
        "right_foot_index"
      ],
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "ankle_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_ankle",
      "expose": false
    },
    {
      "id": "ankle_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "ankle_speed",
      "expose": true
    },
    {
      "id": "knee_alignment_x",
      "primitive": "position",
      "mode": "distance",
      "point": "right_knee",
      "reference": "right_ankle",
      "expose": true
    },
    {
      "id": "hip_drop",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    }
  ],
  "available_views": [
