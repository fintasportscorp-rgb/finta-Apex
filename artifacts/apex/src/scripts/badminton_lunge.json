      "rationale_en": "Reference view: knee flexion, trunk lean, ankle dorsi-flexion — Kuntze 2010.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_foot_index",
        "right_heel"
      ],
      "measures": [
        {
