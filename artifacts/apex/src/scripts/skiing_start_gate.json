{
  "id": "skiing_start_gate",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "skiing",
  "gesture": "Départ de portillon",
  "description": "Départ en vue sagittale : flexion initiale, poussée bâtons, extension explosive. Usage : départ de course.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_elbow",
    "right_wrist"
  ],
  "height": "full",
  "measures": [
    {
      "id": "knee_extension",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_extension",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "elbow_extension",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "ankle_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_ankle",
      "expose": false
    },
    {
      "id": "ankle_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "ankle_speed",
      "expose": true
    },
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": false
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : poussée des bras (bâtons), extension des jambes, inclinaison tronc.",
      "rationale_en": "Reference view: pole push, leg extension, trunk lean.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "knee_extension",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "hip_extension",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "elbow_extension",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        },
        {
          "id": "ankle_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_ankle",
          "expose": false
        },
        {
          "id": "ankle_acceleration",
          "primitive": "acceleration",
          "mode": "linear",
          "source_measure": "ankle_speed",
          "expose": true
        },
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": false
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:ankle_speed",
      "op": "rises_above",
      "threshold": 0.8,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:ankle_speed",
      "op": "falls_below",
      "threshold": 0.3,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 5
  },
  "phases": [
    {
      "id": "chargement",
      "until": {
        "signal": "angle:knee_angle",
        "event": "minimum"
      }
    },
    {
      "id": "poussee",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:knee_angle",
    "event": "minimum"
  },
  "outputs": [
    "knee_extension",
    "hip_extension",
    "trunk_inclination",
    "elbow_extension",
    "wrist_speed",
    "ankle_acceleration"
  ],
  "report_highlights": [
    "knee_extension",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "session_type",
      "label": "Type de séance",
      "type": "single_select",
      "options": [
        "bilan initial",
        "suivi",
        "entraînement",
        "compétition"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "condition",
      "label": "Condition",
      "type": "single_select",
      "options": [
        "simulation à sec",
        "neige",
        "vidéo"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
