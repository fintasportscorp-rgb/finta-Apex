{
  "id": "gymnastics_split",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "gymnastics",
  "gesture": "Grand écart (split)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "left_hip",
    "left_knee",
    "left_ankle",
    "right_shoulder"
  ],
  "height": "full",
  "measures": [
    {
      "id": "right_leg_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "left_leg_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_hip",
        "left_knee"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "leg_spread_lateral",
      "primitive": "position",
      "mode": "distance",
      "point": "right_ankle",
      "reference": "left_ankle",
      "expose": true
    },
    {
      "id": "hip_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "y",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    }
  ],
