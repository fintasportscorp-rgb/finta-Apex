          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "cyclic",
    "event": {
      "signal": "speed:foot_speed",
      "event": "peak"
    }
  },
  "outputs": [
    "knee_angle",
    "knee_angle_left",
    "ankle_angle",
    "trunk_inclination",
    "foot_speed",
    "shoulder_level",
    "hip_sway",
    "hip_drop_post",
    "shoulder_level_post",
    "hip_sway_post",
    "shoulder_rotation",
    "hip_rotation",
    "foot_acceleration",
    "foot_strike_angle"
  ],
  "report_highlights": [
    "knee_angle",
    "foot_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "session_type",
      "label": "Type de séance",
      "type": "single_select",
      "options": [
        "bilan initial",
        "suivi",
        "rééducation",
        "entraînement"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "vitesse",
      "label": "Vitesse de marche",
      "type": "single_select",
      "options": [
        "lente",
        "normale",
        "rapide"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "assistance",
      "label": "Aide technique",
      "type": "single_select",
      "options": [
        "aucune",
        "canne",
        "déambulateur"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "symmetry_pairs": [
    {
      "right": "knee_angle",
      "left": "knee_angle_left"
    }
  ]
