{
  "id": "football_cut",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "football",
  "gesture": "Changement de direction (cut/crochet)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
