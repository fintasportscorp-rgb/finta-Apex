  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:hip_tilt",
      "op": "rises_above",
      "threshold": 10,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:hip_tilt",
      "op": "falls_below",
      "threshold": 5,
      "unit": "deg"
    },
    "min_duration_s": 0.1,
    "max_duration_s": 1
  },
  "outputs": [
    "shoulder_tilt",
    "hip_tilt",
    "left_knee_flexion",
    "right_knee_flexion",
    "knee_alignment_right",
    "shoulder_tilt_post",
    "hip_tilt_post",
