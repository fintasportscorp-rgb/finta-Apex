  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:knee_angle",
      "op": "falls_below",
      "threshold": 140,
      "unit": "deg"
    },
    "end": {
      "signal": "speed:ankle_speed",
      "op": "falls_below",
      "threshold": 0.3,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 8
  },
  "phases": [
    {
      "id": "impact",
      "until": {
        "signal": "angle:knee_angle",
        "event": "minimum"
      }
    },
    {
      "id": "stabilisation",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:knee_angle",
    "event": "minimum"
  },
  "outputs": [
    "knee_angle",
    "hip_angle",
    "trunk_inclination",
    "hip_position_y",
    "left_knee_flexion",
    "right_knee_flexion",
    "knee_alignment_right",
    "knee_alignment_left",
    "shoulder_rotation",
    "hip_rotation",
    "ankle_acceleration"
  ],
  "report_highlights": [
    "knee_angle",
    "trunk_inclination"
  ],
  "inputs": [
