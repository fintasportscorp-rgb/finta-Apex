{
  "id": "athletics_javelin",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "athletics",
  "gesture": "Lancer de javelot — armé à lâcher",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip"
  ],
  "height": "full",
  "distance_rule": "corps entier + 20%",
  "measures": [
    {
      "id": "shoulder_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_shoulder",
        "right_elbow"
      ],
      "expose": true
    },
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "trunk_lean",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : armé épaule-coude, whip à l'accélération, pic de vitesse main — Morriss 1996.",
      "rationale_en": "Reference view: shoulder-elbow load, whip at acceleration, peak hand speed — Morriss 1996.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_shoulder",
            "right_elbow"
          ],
          "expose": true
        },
        {
          "id": "elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "trunk_lean",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:elbow_angle",
      "op": "rises_above",
      "threshold": 120,
      "unit": "deg"
    },
    "end": {
      "signal": "speed:right_wrist",
      "op": "falls_below",
      "threshold": 0.5,
      "unit": "TL/s"
    },
    "min_duration_s": 0.2,
    "max_duration_s": 2
  },
  "phases": [
    {
      "id": "arme",
      "until": {
        "signal": "speed:right_wrist",
        "event": "peak"
      }
    },
    {
      "id": "lacher",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:right_wrist",
    "event": "peak"
  },
  "outputs": [
    "shoulder_angle",
    "elbow_angle",
    "trunk_lean",
    "wrist_speed"
  ],
  "report_highlights": [
    "elbow_angle",
    "wrist_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "javelin_weight",
      "label": "Poids du javelot (g)",
      "type": "single_select",
      "options": [
        "600g",
        "700g",
        "800g"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "grip_type",
      "label": "Prise en main",
      "type": "single_select",
      "options": [
        "pouce-index",
        "pouce-majeur",
        "américaine"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
