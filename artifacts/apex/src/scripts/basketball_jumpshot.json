{
  "id": "basketball_jumpshot",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "basketball",
  "gesture": "Tir en suspension (jump shot)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_elbow",
    "right_wrist"
  ],
  "height": "full",
  "distance_rule": "corps entier + 15%",
  "measures": [
    {
      "id": "knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "shoulder_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_elbow"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "elbow_alignment_x",
      "primitive": "position",
      "mode": "distance",
      "point": "right_elbow",
      "reference": "right_shoulder",
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    },
    {
      "id": "jump_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "y",
      "expose": true
    },
    {
      "id": "release_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "y",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : chaîne cinétique verticale, élévation bras, snap poignet — Knudson 1993.",
      "rationale_en": "Reference view: vertical kinetic chain, arm elevation, wrist snap — Knudson 1993.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "shoulder_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_elbow"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        },
        {
          "id": "jump_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "hip_center",
          "axis": "y",
          "expose": true
        },
        {
          "id": "release_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_wrist",
          "axis": "y",
          "expose": true
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : alignement coude sous l'épaule (E de BEEF), symétrie au release.",
      "rationale_en": "Face-on: elbow-under-shoulder alignment (E in BEEF), release symmetry.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "elbow_alignment_x",
          "primitive": "position",
          "mode": "distance",
          "point": "right_elbow",
          "reference": "right_shoulder",
          "expose": true
        },
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "elbow_alignment_x",
          "primitive": "position",
          "mode": "distance",
          "point": "right_elbow",
          "reference": "right_shoulder",
          "expose": true
        },
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        },
        {
          "id": "hip_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_hip",
            "right_hip"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:knee_flexion",
      "op": "falls_below",
      "threshold": 155,
      "unit": "deg"
    },
    "end": {
      "signal": "speed:right_wrist",
      "op": "falls_below",
      "threshold": 0.3,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 2
  },
  "phases": [
    {
      "id": "preparation",
      "until": {
        "signal": "angle:knee_flexion",
        "event": "minimum"
      }
    },
    {
      "id": "extension",
      "until": {
        "signal": "speed:right_wrist",
        "event": "peak"
      }
    },
    {
      "id": "lacher",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:right_wrist",
    "event": "peak"
  },
  "outputs": [
    "knee_flexion",
    "elbow_angle",
    "shoulder_elevation",
    "wrist_speed",
    "elbow_alignment_x",
    "shoulder_level",
    "shoulder_rotation",
    "hip_rotation",
    "jump_height",
    "release_height"
  ],
  "report_highlights": [
    "knee_flexion",
    "elbow_angle"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "shot_type",
      "label": "Type de tir",
      "type": "single_select",
      "options": [
        "suspension",
        "lay-up",
        "3 pts"
      ],
      "scope": "instance",
      "required": false
    },
    {
      "id": "distance_panier",
      "label": "Distance panier (m)",
      "type": "number",
      "scope": "instance",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "ball_tracking": {
    "enabled": true,
    "sport_preset": "basketball"
  }
}
