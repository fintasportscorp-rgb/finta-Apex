{
  "id": "cycling_attack_seated",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "cycling",
  "gesture": "Attaque en position assise",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "both",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_foot_index",
    "right_heel"
  ],
  "height": "full",
  "measures": [
    {
      "id": "knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "knee_angle_left",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "ankle_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_knee",
        "right_ankle",
        "right_foot_index"
      ],
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "knee_ang_speed",
      "primitive": "speed",
      "mode": "angular",
      "source_measure": "knee_angle",
      "expose": true
    },
    {
      "id": "knee_ang_acceleration",
      "primitive": "acceleration",
      "mode": "angular",
      "source_measure": "knee_ang_speed",
      "expose": true
    },
    {
      "id": "knee_alignment_right",
      "primitive": "position",
      "mode": "distance",
      "point": "right_knee",
      "reference": "right_ankle",
      "expose": true
    },
    {
      "id": "knee_alignment_left",
      "primitive": "position",
      "mode": "distance",
      "point": "left_knee",
      "reference": "left_ankle",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : amplitude genou-hanche, cadence, stabilité du tronc — méthodologie bike fit (Bini 2011).",
      "rationale_en": "Reference view: knee-hip range, cadence, trunk stability — bike fit methodology (Bini 2011).",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_foot_index",
        "right_heel"
      ],
      "measures": [
        {
          "id": "knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "knee_angle_left",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_hip",
            "left_knee",
            "left_ankle"
          ],
          "expose": true
        },
        {
          "id": "hip_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": true
        },
        {
          "id": "ankle_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_knee",
            "right_ankle",
            "right_foot_index"
          ],
          "expose": true
        },
        {
          "id": "foot_strike_angle",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_heel",
            "right_foot_index"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "knee_ang_speed",
          "primitive": "speed",
          "mode": "angular",
          "source_measure": "knee_angle",
          "expose": true
        },
        {
          "id": "knee_ang_acceleration",
          "primitive": "acceleration",
          "mode": "angular",
          "source_measure": "knee_ang_speed",
          "expose": true
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : knee tracking (alignement vertical genou/cheville en pédalage), symétrie.",
      "rationale_en": "Face-on: knee tracking (vertical knee/ankle alignment during pedaling), symmetry.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_hip",
        "right_hip",
        "left_knee",
        "right_knee",
        "left_ankle",
        "right_ankle",
        "left_shoulder",
        "right_shoulder"
      ],
      "measures": [
        {
          "id": "knee_alignment_right",
          "primitive": "position",
          "mode": "distance",
          "point": "right_knee",
          "reference": "right_ankle",
          "expose": true
        },
        {
          "id": "knee_alignment_left",
          "primitive": "position",
          "mode": "distance",
          "point": "left_knee",
          "reference": "left_ankle",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_hip",
        "right_hip",
        "left_knee",
        "right_knee",
        "left_ankle",
        "right_ankle",
        "left_shoulder",
        "right_shoulder"
      ],
      "measures": [
        {
          "id": "knee_alignment_right",
          "primitive": "position",
          "mode": "distance",
          "point": "right_knee",
          "reference": "right_ankle",
          "expose": true
        },
        {
          "id": "knee_alignment_left",
          "primitive": "position",
          "mode": "distance",
          "point": "left_knee",
          "reference": "left_ankle",
          "expose": true
        },
        {
          "id": "shoulder_rotation",
          "primitive": "rotation",
          "mode": "orientation_folded",
          "points": [
            "left_shoulder",
            "right_shoulder"
          ],
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:knee_ang_speed",
      "op": "rises_above",
      "threshold": 200,
      "unit": "deg/s"
    },
    "end": {
      "signal": "rest",
      "duration_s": 1
    },
    "min_duration_s": 0.3,
    "max_duration_s": 5
  },
  "outputs": [
    "knee_angle",
    "knee_angle_left",
    "hip_angle",
    "ankle_angle",
    "trunk_inclination",
    "knee_ang_speed",
    "knee_alignment_right",
    "knee_alignment_left",
    "shoulder_rotation",
    "knee_ang_acceleration",
    "foot_strike_angle"
  ],
  "report_highlights": [
    "knee_ang_speed",
    "hip_angle"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "attack_type",
      "label": "Type d'attaque",
      "type": "single_select",
      "options": [
        "soudaine",
        "progressive"
      ],
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "symmetry_pairs": [
    {
      "right": "knee_angle",
      "left": "knee_angle_left"
    }
  ]
}
