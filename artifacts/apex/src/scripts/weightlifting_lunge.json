{
  "id": "weightlifting_lunge",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "weightlifting",
  "gesture": "Fente (lunge)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder"
  ],
  "height": "full",
  "measures": [
    {
      "id": "front_knee_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "hip_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_hip",
        "right_knee"
      ],
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "front_knee",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": false
    },
    {
      "id": "knee_alignment_x",
      "primitive": "position",
      "mode": "distance",
      "point": "right_knee",
      "reference": "right_ankle",
      "expose": true
    },
    {
      "id": "hip_drop",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "left_hip"
      ],
      "axis": "horizontal",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : flexion genou avant, verticalité du tronc, hauteur genou arrière.",
      "rationale_en": "Reference view: front knee flexion, trunk verticality, rear knee height.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder"
      ],
      "measures": [
        {
          "id": "front_knee_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "hip_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_hip",
            "right_knee"
          ],
          "expose": true
        },
        {
          "id": "trunk_inclination",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "right_shoulder"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "front_knee",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": false
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : alignement vertical genou-cheville (prévention LCA).",
      "rationale_en": "Face-on: vertical knee-ankle alignment (ACL prevention).",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "measures": [
        {
          "id": "knee_alignment_x",
          "primitive": "position",
          "mode": "distance",
          "point": "right_knee",
          "reference": "right_ankle",
          "expose": true
        },
        {
          "id": "hip_drop",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "measures": [
        {
          "id": "knee_alignment_x",
          "primitive": "position",
          "mode": "distance",
          "point": "right_knee",
          "reference": "right_ankle",
          "expose": true
        },
        {
          "id": "hip_drop",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_hip",
            "left_hip"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:front_knee",
      "op": "falls_below",
      "threshold": 130,
      "unit": "deg"
    },
    "end": {
      "signal": "angle:front_knee",
      "op": "rises_above",
      "threshold": 165,
      "unit": "deg"
    },
    "min_duration_s": 0.5,
    "max_duration_s": 5
  },
  "outputs": [
    "front_knee_angle",
    "hip_angle",
    "trunk_inclination",
    "knee_alignment_x",
    "hip_drop"
  ],
  "report_highlights": [
    "front_knee_angle",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "load_kg",
      "label": "Charge (kg)",
      "type": "number",
      "required": false
    },
    {
      "id": "lunge_type",
      "label": "Type de fente",
      "type": "single_select",
      "options": [
        "statique",
        "alterné",
        "bulgare"
      ],
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ]
}
