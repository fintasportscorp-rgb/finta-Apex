{
  "id": "badminton_drop",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "badminton",
  "gesture": "Amorti (drop)",
  "description": "Drop contrôlé : bras haut, décélération poignet. Usage : finesse réseau.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "right",
  "required_visible": [
    "right_shoulder",
    "right_elbow",
    "right_wrist",
    "right_hip"
  ],
  "height": "full",
  "measures": [
    {
      "id": "shoulder_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_elbow"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : armé overhead + ralentissement contrôlé à l'impact (déception).",
      "rationale_en": "Reference view: overhead load + controlled deceleration at impact (deception).",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_shoulder",
        "right_elbow",
        "right_wrist",
        "right_hip"
      ],
      "measures": [
        {
          "id": "shoulder_elevation",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "right_elbow"
          ],
          "axis": "vertical",
          "expose": true
        },
        {
          "id": "elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.8,
      "unit": "TL/s"
    },
    "end": {
      "signal": "speed:wrist_speed",
      "op": "falls_below",
      "threshold": 0.2,
      "unit": "TL/s"
    },
    "min_duration_s": 0.15,
    "max_duration_s": 2
  },
  "phases": [
    {
      "id": "préparation",
      "until": {
        "signal": "angle:elbow_angle",
        "event": "minimum"
      }
    },
    {
      "id": "touche",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:wrist_speed",
    "event": "peak"
  },
  "outputs": [
    "shoulder_elevation",
    "elbow_angle",
    "wrist_speed"
  ],
  "report_highlights": [
    "elbow_angle",
    "shoulder_elevation"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "session_type",
      "label": "Type de séance",
      "type": "single_select",
      "options": [
        "bilan initial",
        "suivi",
        "entraînement",
        "compétition"
      ],
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "ball_tracking": {
    "enabled": true,
    "sport_preset": "badminton"
  }
}
