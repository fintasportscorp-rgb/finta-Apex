  ],
  "segmentation": {
    "mode": "cyclic",
    "cycle_signal": "knee_angle",
    "boundary": "local_maxima",
    "min_period_s": 0.5
  },
  "outputs": [
    "knee_angle",
    "knee_angle_left",
    "hip_angle",
    "ankle_angle",
    "trunk_inclination",
    "elbow_angle",
    "knee_ang_speed",
    "knee_alignment_right",
    "knee_alignment_left",
    "hip_sway",
    "shoulder_rotation",
    "hip_rotation",
    "knee_ang_acceleration",
    "foot_strike_angle",
    "cadence"
  ],
  "report_highlights": [
    "knee_angle",
    "trunk_inclination"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "cadence_target",
      "label": "Cadence cible (rpm)",
      "type": "number",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "resistance_level",
      "label": "Résistance",
