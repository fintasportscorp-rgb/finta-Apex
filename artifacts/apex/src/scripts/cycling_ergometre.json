          "expose": true
        },
        {
          "id": "ankle_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_knee",
            "right_ankle",
            "right_foot_index"
          ],
          "expose": true
        },
        {
          "id": "foot_strike_angle",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_heel",
            "right_foot_index"
          ],
          "axis": "horizontal",
          "expose": true
        },
        {
          "id": "trunk_inclination",
