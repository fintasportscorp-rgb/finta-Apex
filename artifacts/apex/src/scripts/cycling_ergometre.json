          "id": "knee_ang_acceleration",
          "primitive": "acceleration",
          "mode": "angular",
          "source_measure": "knee_ang_speed",
          "expose": true
        }
      ]
    },
    {
      "view": "frontal",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Face-on : knee tracking vertical bilatéral (knee-in / knee-out) et déport latéral de bassin sur ergomètre.",
      "rationale_en": "Face-on: bilateral vertical knee tracking (knee-in / knee-out) and lateral hip sway on ergometer.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_hip",
        "right_hip",
        "left_knee",
        "right_knee",
