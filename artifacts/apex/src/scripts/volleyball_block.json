  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:right_knee_flexion",
      "op": "falls_below",
      "threshold": 155
    },
    "end": {
      "signal": "rest",
      "duration_s": 0.5
    },
    "min_duration_s": 0.3,
    "max_duration_s": 2
  },
  "outputs": [
    "left_knee_flexion",
    "right_knee_flexion",
    "shoulder_tilt",
    "left_arm_elevation",
    "right_arm_elevation",
    "wrist_speed",
    "wrist_position_y",
    "wrist_position_x"
  ],
  "report_highlights": [
    "right_knee_flexion",
    "shoulder_tilt"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
