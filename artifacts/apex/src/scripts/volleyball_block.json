{
  "id": "volleyball_block",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "volleyball",
  "gesture": "Contre (block)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_hip",
    "right_hip",
    "left_knee",
    "right_knee",
    "left_shoulder",
    "right_shoulder",
    "left_wrist",
    "right_wrist"
  ],
  "height": "full",
  "measures": [
    {
      "id": "left_knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "right_knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "shoulder_tilt",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "left_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "left_shoulder",
        "left_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "right_arm_elevation",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "right_wrist"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    },
    {
      "id": "wrist_position_y",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "y",
      "expose": true
    },
    {
      "id": "wrist_position_x",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "x",
      "expose": true
    }
  ],
  "available_views": [
