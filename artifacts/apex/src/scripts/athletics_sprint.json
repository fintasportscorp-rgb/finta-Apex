{
  "id": "athletics_sprint",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "athletics",
  "gesture": "Sprint — foulée (phase d'appui)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "sagittal_right",
  "side": "both",
  "required_visible": [
    "right_hip",
    "right_knee",
    "right_ankle",
    "right_shoulder",
    "right_foot_index",
    "right_elbow",
    "right_wrist",
    "right_heel"
  ],
  "height": "full",
  "distance_rule": "corps entier + 20%",
  "measures": [
    {
      "id": "knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "knee_flexion_left",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    },
    {
      "id": "ankle_dorsiflexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_knee",
        "right_ankle",
        "right_foot_index"
      ],
      "expose": true
    },
    {
      "id": "foot_strike_angle",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_heel",
        "right_foot_index"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_hip",
        "right_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "foot_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_foot_index",
      "expose": true
    },
    {
      "id": "foot_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "foot_speed",
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "hip_sway",
      "primitive": "position",
      "mode": "amplitude",
      "point": "hip_center",
      "axis": "x",
      "expose": true
    },
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    },
    {
      "id": "arm_swing_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "sagittal_right",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : flexion d'amortissement, extension de propulsion, dorsi-flexion à l'attaque.",
      "rationale_en": "Reference view: amortization flexion, propulsion extension, ankle dorsi-flexion at contact.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_foot_index",
        "right_elbow",
        "right_wrist",
        "right_heel"
      ],
      "measures": [
        {
          "id": "knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "knee_flexion_left",
