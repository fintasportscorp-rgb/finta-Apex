  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "angle:knee_angle_right",
      "op": "falls_below",
      "threshold": 150,
      "unit": "deg"
    },
    "end": {
      "signal": "speed:foot_speed",
      "op": "falls_below",
      "threshold": 0.3,
      "unit": "TL/s"
    },
    "min_duration_s": 0.3,
    "max_duration_s": 10
  },
  "phases": [
    {
      "id": "descente",
      "until": {
        "signal": "angle:knee_angle_right",
        "event": "minimum"
      }
    },
    {
      "id": "remontee",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "angle:knee_angle_right",
    "event": "minimum"
  },
  "outputs": [
    "knee_alignment_right",
    "knee_alignment_left",
    "hip_drop",
    "shoulder_level",
    "knee_angle",
    "hip_angle",
    "trunk_inclination",
    "spine_alignment_post",
    "hip_level_post",
    "knee_alignment_right_post",
    "shoulder_rotation",
    "hip_rotation",
    "foot_acceleration"
  ],
  "report_highlights": [
    "knee_angle",
    "hip_drop"
  ],
  "inputs": [
