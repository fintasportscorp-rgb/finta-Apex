  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:left_wrist",
      "op": "rises_above",
      "threshold": 0.5,
      "unit": "TL/s"
    },
    "end": {
      "signal": "rest",
      "duration_s": 0.4
    },
    "min_duration_s": 0.25,
    "max_duration_s": 2.5
  },
  "phases": [
    {
      "id": "preparation",
      "until": {
        "signal": "speed:left_wrist",
        "event": "rises_to_max"
      }
    },
    {
      "id": "impact",
      "until": {
        "signal": "speed:left_wrist",
        "event": "peak"
      }
    },
    {
      "id": "follow_through",
      "until": "end"
    }
  ],
  "key_event": {
    "signal": "speed:left_wrist",
    "event": "peak"
  },
  "outputs": [
    "shoulder_rotation",
    "hip_rotation",
    "hitting_plane",
    "wrist_separation",
