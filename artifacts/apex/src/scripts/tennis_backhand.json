{
  "id": "tennis_backhand",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "tennis",
  "gesture": "Revers — plan de frappe",
  "description": "Plan de frappe au revers (deux mains ou une main) : alignement scapulaire, fermeture du tronc avant impact, plan raquette.",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "left",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_elbow",
    "left_wrist",
    "right_wrist",
    "left_hip",
    "right_hip"
  ],
  "height": "hip",
  "distance_rule": "corps entier + 30%",
  "measures": [
    {
      "id": "shoulder_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_shoulder",
        "right_shoulder"
      ],
      "expose": true
    },
    {
      "id": "hip_rotation",
      "primitive": "rotation",
      "mode": "orientation_folded",
      "points": [
        "left_hip",
        "right_hip"
      ],
      "expose": true
    },
    {
      "id": "hitting_plane",
      "primitive": "hitting_plane",
      "mode": "left",
      "points": [
        "left_hip",
        "right_hip",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_separation",
      "primitive": "position",
      "mode": "distance",
      "point": "left_wrist",
      "reference": "right_wrist",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "left_wrist",
      "expose": true
    },
    {
      "id": "elbow_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "left_elbow",
      "expose": true
    },
    {
      "id": "elbow_acceleration",
      "primitive": "acceleration",
      "mode": "linear",
      "source_measure": "elbow_speed",
      "expose": true
    },
    {
      "id": "elbow_extension_lead",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_elbow",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_path_y",
      "primitive": "position",
      "mode": "amplitude",
      "point": "left_wrist",
      "axis": "y",
      "expose": true
    },
    {
      "id": "trunk_inclination",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "left_hip",
        "left_shoulder"
      ],
      "axis": "vertical",
      "expose": true
    },
    {
      "id": "knee_flexion_lead",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_hip",
        "left_knee",
        "left_ankle"
      ],
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "frontal",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : alignement épaules/hanches, plan de frappe, écartement des poignets (revers deux mains).",
