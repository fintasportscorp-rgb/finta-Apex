{
  "id": "volleyball_set",
  "version": "1.1.0",
  "dsl_version": "1.1",
  "discipline": "volleyball",
  "gesture": "Passe haute (set)",
  "movement_type": "finite",
  "cv_model": "blazepose-full@1.x",
  "view": "frontal",
  "side": "both",
  "required_visible": [
    "left_shoulder",
    "right_shoulder",
    "left_elbow",
    "right_elbow",
    "left_wrist",
    "right_wrist",
    "left_hip",
    "right_hip"
  ],
  "height": "full",
  "measures": [
    {
      "id": "left_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "left_shoulder",
        "left_elbow",
        "left_wrist"
      ],
      "expose": true
    },
    {
      "id": "right_elbow_angle",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_shoulder",
        "right_elbow",
        "right_wrist"
      ],
      "expose": true
    },
    {
      "id": "wrist_separation",
      "primitive": "position",
      "mode": "distance",
      "point": "left_wrist",
      "reference": "right_wrist",
      "expose": true
    },
    {
      "id": "shoulder_level",
      "primitive": "angle",
      "mode": "segment_axis",
      "points": [
        "right_shoulder",
        "left_shoulder"
      ],
      "axis": "horizontal",
      "expose": true
    },
    {
      "id": "knee_flexion",
      "primitive": "angle",
      "mode": "joint",
      "points": [
        "right_hip",
        "right_knee",
        "right_ankle"
      ],
      "expose": true
    },
    {
      "id": "wrist_height",
      "primitive": "position",
      "mode": "amplitude",
      "point": "right_wrist",
      "axis": "y",
      "expose": true
    },
    {
      "id": "wrist_speed",
      "primitive": "speed",
      "mode": "linear",
      "point": "right_wrist",
      "expose": true
    }
  ],
  "available_views": [
    {
      "view": "frontal",
      "priority": 1,
      "primary": true,
      "rationale_fr": "Vue de référence : passe à deux mains, symétrie des coudes et poignets.",
      "rationale_en": "Reference view: two-hand set, elbow and wrist symmetry.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_elbow",
        "right_elbow",
        "left_wrist",
        "right_wrist",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "left_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_shoulder",
            "left_elbow",
            "left_wrist"
          ],
          "expose": true
        },
        {
          "id": "right_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "wrist_separation",
          "primitive": "position",
          "mode": "distance",
          "point": "left_wrist",
          "reference": "right_wrist",
          "expose": true
        },
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    },
    {
      "view": "sagittal_right",
      "priority": 2,
      "primary": false,
      "rationale_fr": "Profil : flexion genoux préparatoire, hauteur du contact balle.",
      "rationale_en": "Side view: preparatory knee flexion, ball contact height.",
      "feasibility_2d": "ok",
      "side": "right",
      "required_visible": [
        "right_hip",
        "right_knee",
        "right_ankle",
        "right_shoulder",
        "right_wrist"
      ],
      "measures": [
        {
          "id": "knee_flexion",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_hip",
            "right_knee",
            "right_ankle"
          ],
          "expose": true
        },
        {
          "id": "wrist_height",
          "primitive": "position",
          "mode": "amplitude",
          "point": "right_wrist",
          "axis": "y",
          "expose": true
        },
        {
          "id": "wrist_speed",
          "primitive": "speed",
          "mode": "linear",
          "point": "right_wrist",
          "expose": true
        }
      ]
    },
    {
      "view": "posterior",
      "priority": 3,
      "primary": false,
      "rationale_fr": "Vue arrière : mêmes mesures bilatérales que la vue frontale, capturées depuis le dos.",
      "rationale_en": "Rear view: same bilateral measures as the frontal view, captured from behind.",
      "feasibility_2d": "ok",
      "side": "both",
      "required_visible": [
        "left_shoulder",
        "right_shoulder",
        "left_elbow",
        "right_elbow",
        "left_wrist",
        "right_wrist",
        "left_hip",
        "right_hip"
      ],
      "measures": [
        {
          "id": "left_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "left_shoulder",
            "left_elbow",
            "left_wrist"
          ],
          "expose": true
        },
        {
          "id": "right_elbow_angle",
          "primitive": "angle",
          "mode": "joint",
          "points": [
            "right_shoulder",
            "right_elbow",
            "right_wrist"
          ],
          "expose": true
        },
        {
          "id": "wrist_separation",
          "primitive": "position",
          "mode": "distance",
          "point": "left_wrist",
          "reference": "right_wrist",
          "expose": true
        },
        {
          "id": "shoulder_level",
          "primitive": "angle",
          "mode": "segment_axis",
          "points": [
            "right_shoulder",
            "left_shoulder"
          ],
          "axis": "horizontal",
          "expose": true
        }
      ]
    }
  ],
  "segmentation": {
    "mode": "discrete",
    "start": {
      "signal": "speed:wrist_speed",
      "op": "rises_above",
      "threshold": 0.2
    },
    "end": {
      "signal": "rest",
      "duration_s": 0.3
    },
    "min_duration_s": 0.1,
    "max_duration_s": 1
  },
  "outputs": [
    "left_elbow_angle",
    "right_elbow_angle",
    "wrist_separation",
    "shoulder_level",
    "knee_flexion",
    "wrist_height",
    "wrist_speed"
  ],
  "report_highlights": [
    "right_elbow_angle",
    "wrist_speed"
  ],
  "inputs": [
    {
      "id": "readiness_physical",
      "label": "Fraîcheur physique",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "readiness_cognitive",
      "label": "Acuité mentale",
      "type": "rpe_readiness",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "set_direction",
      "label": "Direction de passe",
      "type": "single_select",
      "options": [
        "devant",
        "derrière",
        "côté"
      ],
      "required": false
    },
    {
      "id": "rpe_physical",
      "label": "Effort physique (RPE-P)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "rpe_cognitive",
      "label": "Effort mental (RPE-C)",
      "type": "rpe",
      "scope": "sequence",
      "required": false
    },
    {
      "id": "note",
      "label": "Note",
      "type": "textarea",
      "scope": "sequence",
      "required": false
    }
  ],
  "ball_tracking": {
    "enabled": true,
    "sport_preset": "volleyball"
  }
}
